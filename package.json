{
  "name": "qa-testing-portal",
  "version": "1.0.0",
  "description": "Node.js QA testing portal with Playwright automation and MySQL report storage",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "order-flow": "node order_placement/run-order-flow.mjs",
    "quick-check": "node automation/form-functional-checks.mjs",
    "check": "node --check server.js"
  },
  "keywords": ["qa", "testing", "playwright", "reports", "express"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mysql2": "^3.6.5",
    "cors": "^2.8.5",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "playwright": "1.58.2"
  }
}
