NODE_ENV=production
PORT=3000

# Frontend/API access
CORS_ORIGIN=https://your-domain.example
JWT_SECRET=replace-with-a-long-random-secret
JWT_TTL_SECONDS=28800

# MySQL database
DB_HOST=localhost
DB_PORT=3306
DB_USER=testing_portal_user
DB_PASSWORD=replace-with-a-strong-password
DB_NAME=testing_portal
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_URL=mysql://testing_portal_user:password@localhost:3306/testing_portal

# Optional automation tuning
SECURITY_REPORT_MODE=balanced
SECURITY_REPORT_BUDGET_SECONDS=180
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_USE_BUNDLED_CHROMIUM=true
